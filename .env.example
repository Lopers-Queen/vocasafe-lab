# VocaSafe Lab D4 environment variables
#
# NEXT_PUBLIC_* variables are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never import or access this from Client Components.
# Use only in API routes, Server Actions, or other server-only modules.
SUPABASE_SERVICE_ROLE_KEY=

# Optional AI provider configuration. API keys are server-only.
AI_PROVIDER=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

# Supabase Storage bucket for report evidence photos.
SUPABASE_STORAGE_BUCKET=report-evidence

# Do not commit a real .env file with secrets.
# Keep production values in Vercel/Supabase environment settings.
